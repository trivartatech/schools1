From bf4939ba26891d2e7b783cbc180aca2eae6b54c6 Mon Sep 17 00:00:00 2001
From: Prajw <prajw@trivartatech>
Date: Sun, 26 Apr 2026 17:26:47 +0530
Subject: [PATCH] fix: new parent admissions get default 'parent123' password
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

AdmissionService::admit() previously set every new parent's password to
a random 10-char string that was never shown to anyone — so admins
adding students through the web couldn't tell parents how to log in to
the mobile app, and parents got "Invalid credentials" forever.

Now uses the same default ('parent123') as the existing
portal:create-users artisan command, so the rule is consistent
everywhere: parent username = primary_phone, default password =
parent123, change after first login.

Co-Authored-By: Claude Opus 4.7 <noreply@anthropic.com>
---
 app/Services/AdmissionService.php | 4 +++-
 1 file changed, 3 insertions(+), 1 deletion(-)

diff --git a/app/Services/AdmissionService.php b/app/Services/AdmissionService.php
index df35846..03ec74c 100644
--- a/app/Services/AdmissionService.php
+++ b/app/Services/AdmissionService.php
@@ -25,12 +25,14 @@ public function admitStudent(array $data, int $schoolId, int $academicYearId)
 
             if (!$parent) {
                 // Create User for Parent
+                // Default password matches the artisan portal:create-users
+                // command so admins / parents always know the initial login.
                 $parentUser = User::create([
                     'school_id' => $schoolId,
                     'name'      => $data['father_name'] ?: ($data['guardian_name'] ?: 'Parent'),
                     'username'  => $data['primary_phone'],
                     'phone'     => $data['primary_phone'],
-                    'password'  => \Illuminate\Support\Facades\Hash::make(\Illuminate\Support\Str::random(10)),
+                    'password'  => \Illuminate\Support\Facades\Hash::make('parent123'),
                     'user_type' => 'parent',
                     'is_active' => true,
                 ]);
-- 
