From 1d22d8611acfffbceb378bd49730098363a6b476 Mon Sep 17 00:00:00 2001
From: Prajw <prajw@trivartatech>
Date: Sun, 26 Apr 2026 19:31:09 +0530
Subject: [PATCH] fix: password resets now default to 'password' instead of
 random string
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Per request — both single-row Reset and Bulk Reset now set the new
password to the literal string 'password' instead of a fresh random
10-char value. Easier for admins to communicate verbally / via SMS;
users are still expected to change it on first login.

createMissing() is unchanged and still uses the role-specific defaults
('parent123' for parents, DOB or 'student123' for students).

Co-Authored-By: Claude Opus 4.7 <noreply@anthropic.com>
---
 app/Http/Controllers/School/UserManagementController.php | 6 ++++--
 1 file changed, 4 insertions(+), 2 deletions(-)

diff --git a/app/Http/Controllers/School/UserManagementController.php b/app/Http/Controllers/School/UserManagementController.php
index 093856d..073edaa 100644
--- a/app/Http/Controllers/School/UserManagementController.php
+++ b/app/Http/Controllers/School/UserManagementController.php
@@ -86,7 +86,9 @@ public function resetPassword(Request $request, $id)
             return response()->json(['success' => false, 'message' => 'Use the profile page to change your own password.'], 422);
         }
 
-        $newPassword = Str::random(10);
+        // Default reset value — keep simple so admins can communicate it
+        // verbally / via SMS. Users should change it on first login.
+        $newPassword = 'password';
         $user->update(['password' => Hash::make($newPassword)]);
 
         \Illuminate\Support\Facades\Log::info('Password reset by admin', [
@@ -274,7 +276,7 @@ public function bulkReset(Request $request)
 
         DB::transaction(function () use ($users, &$rows) {
             foreach ($users as $u) {
-                $newPassword = Str::random(10);
+                $newPassword = 'password';
                 $u->update(['password' => Hash::make($newPassword)]);
                 // user_type is a backed enum (App\Enums\UserType), so we must
                 // pull ->value rather than relying on string cast.
