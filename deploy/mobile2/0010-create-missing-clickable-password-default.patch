From ed6b6ddc61969993d3250a27d6b9839d440ff38c Mon Sep 17 00:00:00 2001
From: Prajw <prajw@trivartatech>
Date: Sun, 26 Apr 2026 19:36:31 +0530
Subject: [PATCH] fix: Create Missing Logins always clickable, default password
 is 'password'
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Two changes to bring Create Missing in line with the password resets:

1. Button is no longer disabled when missing_counts is zero. Even if
   every parent/student already has a User row, clicking now still
   runs the controller (which silently no-ops, returning a toast
   "No missing accounts to create"). This way admins can re-run
   anytime, e.g. after importing a new batch of students.

2. Default password for newly-created Users is now the literal string
   'password' (was 'parent123' for parents, DOB / 'student123' for
   students). Matches the reset behaviour. Users should change it
   on first login.

3. Always sends type='all' from the button — no longer conditional.
   The controller already handles 'all' to mean "do parents AND
   students in the same call".

Co-Authored-By: Claude Opus 4.7 <noreply@anthropic.com>
---
 .../Controllers/School/UserManagementController.php  | 12 +++---------
 resources/js/Pages/School/Users/Index.vue            |  3 +--
 2 files changed, 4 insertions(+), 11 deletions(-)

diff --git a/app/Http/Controllers/School/UserManagementController.php b/app/Http/Controllers/School/UserManagementController.php
index 073edaa..8aa4ff9 100644
--- a/app/Http/Controllers/School/UserManagementController.php
+++ b/app/Http/Controllers/School/UserManagementController.php
@@ -168,7 +168,7 @@ public function createMissing(Request $request)
                         continue;
                     }
 
-                    $password = 'parent123';
+                    $password = 'password';
                     $user = User::create([
                         'school_id' => $schoolId,
                         'name'      => $parent->father_name ?: ($parent->guardian_name ?: 'Parent'),
@@ -208,13 +208,7 @@ public function createMissing(Request $request)
                         continue;
                     }
 
-                    // Default to DOB (yyyymmdd) if available, else 'student123'
-                    $password = $student->dob
-                        ? str_replace('-', '', $student->dob instanceof \Carbon\Carbon
-                            ? $student->dob->toDateString()
-                            : (string) $student->dob)
-                        : 'student123';
-
+                    $password = 'password';
                     $user = User::create([
                         'school_id' => $schoolId,
                         'name'      => trim(($student->first_name ?? '') . ' ' . ($student->last_name ?? '')),
@@ -249,7 +243,7 @@ public function createMissing(Request $request)
             'count'      => count($created),
             'message'    => count($created) === 0
                 ? 'No missing accounts to create.'
-                : count($created) . ' account(s) created. Default password: parent123 (parents) / DOB or student123 (students).',
+                : count($created) . ' account(s) created. Default password: password',
             'credentials' => $created,
         ]);
     }
diff --git a/resources/js/Pages/School/Users/Index.vue b/resources/js/Pages/School/Users/Index.vue
index 27036d1..ba155ff 100644
--- a/resources/js/Pages/School/Users/Index.vue
+++ b/resources/js/Pages/School/Users/Index.vue
@@ -221,8 +221,7 @@ const getStatusBadgeClass = (active) => active
                           class="text-[11px] font-bold text-amber-700 bg-amber-50 border border-amber-200 px-2.5 py-1 rounded-full">
                         Missing: {{ missing_counts.parents }} parents · {{ missing_counts.students }} students
                     </span>
-                    <Button size="sm" :disabled="bulkBusy || (missing_counts.parents + missing_counts.students) === 0"
-                            @click="createMissing(missing_counts.students > 0 && missing_counts.parents > 0 ? 'all' : (missing_counts.parents > 0 ? 'parent' : 'student'))">
+                    <Button size="sm" :disabled="bulkBusy" @click="createMissing('all')">
                         <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>
                         Create Missing Logins
                     </Button>
