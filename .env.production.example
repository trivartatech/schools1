# =============================================================================
# Generic School ERP — Production .env template
# -----------------------------------------------------------------------------
# Two ways to fill this:
#   A) Edit school-setup.xlsx (friendly UI) → bootstrap.sh converts it for you
#   B) Edit this file directly, save as .env, then run bootstrap.sh
# =============================================================================

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME="REPLACE_ME — School Name"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Asia/Kolkata
APP_URL=https://REPLACE_ME.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ── MySQL ────────────────────────────────────────────────────────────────────
# IMPORTANT: avoid #, $, !, ', \ in passwords — bash sourcing breaks on these.
# Use only letters, digits, and these safe symbols: @ - _ . + = (16+ chars rec.)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=REPLACE_ME_school_erp
DB_USERNAME=REPLACE_ME
DB_PASSWORD=REPLACE_ME

# Optional — only if you want bootstrap.sh to auto-create the DB+user.
# Leave blank if the database+user already exist (e.g., created in CloudPanel).
DB_ROOT_USERNAME=
DB_ROOT_PASSWORD=

# ── School identity (read by config/school.php → GenericSchoolSeeder) ────────
SCHOOL_NAME="REPLACE_ME School Name"
SCHOOL_SLUG=replace-me-school
SCHOOL_CODE=RMS001
SCHOOL_BOARD=CBSE
SCHOOL_EMAIL=admin@REPLACE_ME.com
SCHOOL_PHONE=
SCHOOL_ADDRESS=
SCHOOL_CITY=
SCHOOL_STATE=
SCHOOL_PINCODE=
SCHOOL_WEBSITE=https://REPLACE_ME.com
SCHOOL_PRINCIPAL_NAME=Principal
SCHOOL_TIMEZONE=Asia/Kolkata
SCHOOL_CURRENCY=INR
SCHOOL_LANGUAGE=en

# ── Trust / Organization (parent of school) ──────────────────────────────────
ORG_NAME="REPLACE_ME Trust"
ORG_SLUG=replace-me-trust
ORG_EMAIL=info@REPLACE_ME.com
ORG_WEBSITE=https://REPLACE_ME.com

# ── Initial admin logins (auto-created by GenericSchoolSeeder) ───────────────
SUPER_ADMIN_EMAIL=superadmin@REPLACE_ME.com
ADMIN_EMAIL=admin@REPLACE_ME.com
PRINCIPAL_EMAIL=principal@REPLACE_ME.com
DEFAULT_PASSWORD=ChangeMe@2026

# ── Sessions / Queue / Cache ─────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Mail (fill when ready) ───────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="no-reply@REPLACE_ME.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── AWS S3 (only if storing uploads on S3) ───────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ── Frontend ─────────────────────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"

# ── Integrations (fill when ready) ───────────────────────────────────────────
GEMINI_API_KEY=
GROQ_API_KEY=

# Firebase Cloud Messaging (mobile push notifications)
# Path to Firebase service account JSON file
# Download from: Firebase Console → Project Settings → Service Accounts
FIREBASE_CREDENTIALS=

# Razorpay Payment Gateway (online fee payment)
PAYMENT_GATEWAY=razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Log viewer auth secret (for /log-viewer route)
LOG_VIEWER_SECRET=
