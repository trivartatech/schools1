# =============================================================================
# Schools ERP — Production .env template
# -----------------------------------------------------------------------------
# Two ways to fill this for a new school:
#   A) Fill school-setup.xlsx (friendly UI) → bootstrap.sh converts it automatically
#   B) Copy this file to .env, replace every REPLACE_ME value, run bootstrap.sh
# =============================================================================

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME="REPLACE_ME School Name"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Asia/Kolkata
APP_URL=https://REPLACE_ME.com
APP_LOCALE=en
APP_MAINTENANCE_DRIVER=file

# ERP Edition — set ONCE at install time, controls which modules are active
# full     = Hostel + Transport
# standard = Transport only (no Hostel)
# lite     = neither Hostel nor Transport
ERP_EDITION=full

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
# Use 'info' during initial setup to see provider API logs. Switch to 'error' in production.
LOG_LEVEL=error

# ── Database ──────────────────────────────────────────────────────────────────
# IMPORTANT: avoid #  $  !  '  \ in passwords — bash env parsing breaks on these.
# Safe characters: letters, digits, @ - _ . + = (16+ chars recommended)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=REPLACE_ME_school_erp
DB_USERNAME=REPLACE_ME
DB_PASSWORD=REPLACE_ME

# Optional — only needed if you want bootstrap.sh to auto-create the DB and user.
# Leave blank if the database already exists (e.g. created in CloudPanel).
DB_ROOT_USERNAME=
DB_ROOT_PASSWORD=

# ── School identity ───────────────────────────────────────────────────────────
# Read by config/school.php → used by GenericSchoolSeeder at bootstrap time.
SCHOOL_NAME="REPLACE_ME School Name"
SCHOOL_SLUG=replace-me-school
SCHOOL_CODE=RMS001
SCHOOL_BOARD=CBSE
SCHOOL_EMAIL=admin@REPLACE_ME.com
SCHOOL_PHONE=
SCHOOL_ADDRESS=
SCHOOL_CITY=
SCHOOL_STATE=
SCHOOL_PINCODE=
SCHOOL_WEBSITE=https://REPLACE_ME.com
SCHOOL_PRINCIPAL_NAME=Principal
SCHOOL_TIMEZONE=Asia/Kolkata
SCHOOL_CURRENCY=INR
SCHOOL_LANGUAGE=en

# ── Organisation (trust / parent body) ───────────────────────────────────────
ORG_NAME="REPLACE_ME Trust"
ORG_SLUG=replace-me-trust
ORG_EMAIL=info@REPLACE_ME.com
ORG_WEBSITE=https://REPLACE_ME.com

# ── Initial admin accounts (auto-created by GenericSchoolSeeder) ─────────────
# Change DEFAULT_PASSWORD immediately after first login.
SUPER_ADMIN_EMAIL=superadmin@REPLACE_ME.com
ADMIN_EMAIL=admin@REPLACE_ME.com
PRINCIPAL_EMAIL=principal@REPLACE_ME.com
DEFAULT_PASSWORD=ChangeMe@2026

# ── Sessions / Queue / Cache ──────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database
CACHE_STORE=database

# ── Mail (SMTP) ───────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=REPLACE_ME
MAIL_PORT=587
MAIL_USERNAME=REPLACE_ME
MAIL_PASSWORD=REPLACE_ME
MAIL_FROM_ADDRESS="no-reply@REPLACE_ME.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── AWS S3 (optional — only if storing uploads on S3) ────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-south-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ── Integrations ──────────────────────────────────────────────────────────────

# Razorpay — online fee payment
PAYMENT_GATEWAY=razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Firebase Cloud Messaging — mobile push notifications
# Path to service account JSON: Firebase Console → Project Settings → Service Accounts
FIREBASE_CREDENTIALS=

# AI / LLM providers
GEMINI_API_KEY=
GROQ_API_KEY=

# Log viewer auth token — protects the /log-viewer route
LOG_VIEWER_SECRET=
